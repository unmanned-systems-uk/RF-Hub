<!-- ═══ CONTENT ═══ -->
<div class="container">
<div class="article">

  <!-- Article Meta -->
  <div class="article-meta">
    <span class="article-meta-item">Unit 1 — How Antennas Work</span>
    <span class="article-meta-item">Prerequisites: Lesson 3 (Radiation Patterns)</span>
    <span class="article-meta-item">Equipment: None</span>
